# ═══════════════════════════════════════════════════════════
# Panchakarma Management System — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ── Node ───────────────────────────────────────────────────
NODE_ENV=development

# ── Database (shared by all services) ─────────────────────
DB_NAME=panchakarma_db
DB_USER=panchakarma
DB_PASS=change_this_password
DB_HOST=localhost
DB_PORT=3306
DB_DIALECT=mysql

# ── JWT ────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret_here
JWT_EXPIRES_IN=7d

# ── Service Ports ──────────────────────────────────────────
GATEWAY_PORT=4000
AUTH_PORT=4001
PATIENT_PORT=4002
DOCTOR_PORT=4003
SESSION_PORT=4004
SHOP_PORT=4005
NOTIFICATION_PORT=4006
REPORT_PORT=4007

# ── API Gateway ────────────────────────────────────────────
SERVICE_HOST=localhost
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Frontend ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:4000

# ── Email (optional — set to enable real email) ────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@panchakarma.com

# ── SMS via Twilio (optional) ──────────────────────────────
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_FROM=+1234567890

# ── Redis (optional — for caching & rate limiting) ─────────
REDIS_URL=redis://localhost:6379

# ── Uploads ────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=info
