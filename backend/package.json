{
  "name": "panchakarma-ms",
  "version": "2.0.0",
  "description": "Panchakarma Management Software — Microservices Architecture",
  "private": true,
  "workspaces": [
    "gateway",
    "services/*",
    "shared",
    "frontend"
  ],
  "scripts": {
    "dev":         "concurrently \"npm run dev:gateway\" \"npm run dev:auth\" \"npm run dev:patient\" \"npm run dev:doctor\" \"npm run dev:session\" \"npm run dev:shop\" \"npm run dev:notification\" \"npm run dev:report\"",
    "dev:gateway": "cd gateway && npm run dev",
    "dev:auth":    "cd services/auth-service && npm run dev",
    "dev:patient": "cd services/patient-service && npm run dev",
    "dev:doctor":  "cd services/doctor-service && npm run dev",
    "dev:session": "cd services/session-service && npm run dev",
    "dev:shop":    "cd services/shop-service && npm run dev",
    "dev:notification": "cd services/notification-service && npm run dev",
    "dev:report":  "cd services/report-service && npm run dev",
    "dev:frontend":"cd frontend && npm run dev",
    "build":       "npm run build --workspaces",
    "test":        "npm run test --workspaces",
    "docker:up":   "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "migrate":     "cd database && node run-migrations.js",
    "seed":        "cd database && node seeds/index.js",
    "lint":        "eslint \"**/src/**/*.js\" --fix"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "eslint":       "^8.55.0",
    "nodemon":      "^3.0.2"
  },
  "engines": { "node": ">=18.0.0" }
}
